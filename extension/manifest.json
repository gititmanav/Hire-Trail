{
  "manifest_version": 3,
  "name": "HireTrail — Job Tracker",
  "version": "1.1.0",
  "description": "Track job applications with one click from any job board",
  "permissions": ["activeTab", "storage", "cookies", "identity", "alarms"],
  "host_permissions": [
    "<all_urls>",
    "https://hiretrail.manavkaneria.me/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/extraction-core.js", "content/extractors.config.js", "content/content.js"]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  }
}
