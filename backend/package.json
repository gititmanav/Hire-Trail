{
  "name": "hiretrail-backend",
  "version": "3.0.0",
  "description": "HireTrail API — Internship & Job Application Command Center",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_NO_WARNINGS=1 tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/seed.ts",
    "db:up": "docker compose -f ../docker-compose.yml up -d",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:up:local": "mkdir -p .localdb/mongo && mongod --dbpath .localdb/mongo --port 27017 --fork --logpath .localdb/mongod.log",
    "db:stop:local": "mongosh --port 27017 --quiet --eval \"db.getSiblingDB('admin').shutdownServer()\" || true",
    "db:seed": "tsx scripts/devSeed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/google": "^3.0.73",
    "@ai-sdk/openai": "^3.0.63",
    "@azure/msal-node": "^5.2.1",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@sentry/node": "^9.47.1",
    "ai": "^6.0.182",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "unpdf": "^1.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-local": "^1.0.38",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "license": "MIT"
}
