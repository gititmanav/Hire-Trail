# Copy to .env and fill in values. Never commit .env.

MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/HireTrail?retryWrites=true&w=majority
SESSION_SECRET=use-a-long-random-string-in-production
PORT=5050
NODE_ENV=development
# Browser origin for CORS + OAuth redirects after login.
CLIENT_URL=http://localhost:5173

# Google OAuth (optional; leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5050/api/auth/google/callback

# --- Production (Vercel: set these in the project Environment Variables, NODE_ENV=production) ---
# CLIENT_URL=https://your-app.vercel.app
# GOOGLE_CALLBACK_URL=https://your-app.vercel.app/api/auth/google/callback
# (Must match Authorized redirect URI in Google Cloud Console. Do not use localhost in production.)

# Cloudinary (optional; resume PDF storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JSearch via RapidAPI (optional; powers in-app job search)
JSEARCH_API_KEY=

# Comma-separated emails to grant admin access (e.g. you@example.com,team@example.com)
ADMIN_EMAILS=

# While maintenance_mode is enabled in System Settings, only this email may sign in / use the API. Leave empty for no bypass.
MAINTENANCE_BYPASS_EMAIL=

# Outbound email (admin broadcasts). Uses Gmail SMTP by default.
# EMAIL_APP_PASSWORD must be a Google App Password (https://myaccount.google.com/apppasswords).
EMAIL_SENDER=
EMAIL_SENDER_NAME=HireTrail
EMAIL_APP_PASSWORD=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465

# Sentry error tracking (optional; leave empty to disable).
# Create a Node project at https://sentry.io and paste its DSN here.
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# --- AI platform ---------------------------------------------------------
# 64 hex chars (32 bytes). Encrypts BYOK keys + the admin default key at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Vercel AI Gateway. When set, ALL model calls route through the gateway as
# `provider/model` (e.g. anthropic/claude-haiku-4-5, bedrock/anthropic.claude-3-5-sonnet)
# and per-user BYOK keys are forwarded per-request via providerOptions.gateway.byok.
# Get one at https://vercel.com/dashboard → AI Gateway → API Keys.
# Leave empty to fall back to the per-provider SDK keys below (local dev).
AI_GATEWAY_API_KEY=

# Optional direct per-provider keys, used only when AI_GATEWAY_API_KEY is empty.
# These are the legacy env defaults; the admin default key (DB-backed, set in
# Admin → AI) supersedes them for the platform's default-key flow.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# Gotenberg HTML→PDF service (Chromium route). Deploy to Cloud Run scale-to-zero
# (see backend/DEPLOY_GOTENBERG.md). Empty disables POST /api/resumes/render-pdf.
# e.g. https://gotenberg-xxxxx-uc.a.run.app
GOTENBERG_URL=
