# --- Local development (default) ---
# Browser calls `/api/...`; Vite forwards to your Express server.
VITE_API_PROXY_TARGET=http://localhost:5050

# --- Split frontend + API (e.g. Vercel + Render) ---
# Build-time variable: set in the Vercel project to your public API base **including** `/api`.
# Uncomment and adjust when the SPA is not served from the same origin as the API:
# VITE_API_BASE_URL=https://your-backend.example.com/api
