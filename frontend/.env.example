# --- Local development (default) ---
# Browser calls `/api/...`; Vite forwards to your Express server.
VITE_API_PROXY_TARGET=http://localhost:5050

# --- Same-origin deploy (frontend + API on one host, e.g. Vercel monolith) ---
# Omit VITE_API_BASE_URL so the app uses relative `/api` (correct for hiretrail.vercel.app + /api routes).

# --- Split frontend + API (different hosts) ---
# Build-time: set to your public API base **including** `/api`.
# VITE_API_BASE_URL=https://your-api.example.com/api
